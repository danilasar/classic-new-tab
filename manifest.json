{
  "manifest_version": 2,
  "name": "Classic New Tab",
  "short_name": "CNT",
  "description": "Replaces Chrome's new tab page with a classic apps and most visited layout.",
  "default_locale": "en",
  "version": "0.2.0",
  "chrome_url_overrides": {
    "newtab": "main.html"
  },
  "options_page": "options.html",
  "permissions": [
    "storage",
    "topSites",
    "tabs",
    "webRequest",
    "management",
    "bookmarks",
    "<all_urls>",
    "chrome://favicon/"
  ],
  "background": {
    "scripts": ["js/background.js"]
  },
  "icons": {
    "200": "images/icon200.png",
    "128": "images/icon128.png",
    "19": "images/icon19.png"
  },
  "incognito": "split",
  "minimum_chrome_version": "22"
}
